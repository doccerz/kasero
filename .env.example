# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme
DATABASE_SCHEMA=kasero
DATABASE_NAME=kasero
# Full PostgreSQL connection string used by Drizzle ORM
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/kasero

# ─────────────────────────────────────────────
# API (NestJS — apps/api)
# ─────────────────────────────────────────────
# Port the NestJS API listens on
API_PORT=3001

# Secret used to sign JWT tokens for admin sessions
JWT_SECRET=replace-with-a-long-random-secret

# JWT token expiry (e.g. 8h, 1d)
JWT_EXPIRES_IN=8h

# ─────────────────────────────────────────────
# Admin seed credentials (used only on first run)
# ─────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# ─────────────────────────────────────────────
# Web (Next.js — apps/web)
# ─────────────────────────────────────────────
# Port the Next.js dev server listens on
WEB_PORT=3000

# Internal base URL of the NestJS API, used by Next.js server-side calls only.
# This URL must never be directly accessible by browsers.
INTERNAL_API_URL=http://localhost:3001

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
# Node environment
NODE_ENV=development

# Application timezone — must be Asia/Manila for correct date/billing behavior
TZ=Asia/Manila
